# Core backend
MONGO_URL=mongodb://localhost:27017
DB_NAME=splitbill
ENV=development

# OCR provider selection: auto | google_vision | tesseract
# Recommended for real phone photos: auto
OCR_PROVIDER=auto

# Optional cloud OCR (recommended for higher accuracy on real photos)
# Get API key from Google Cloud Vision API
GOOGLE_VISION_API_KEY=

# Optional explicit Tesseract path (Windows example)
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
