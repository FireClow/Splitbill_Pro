# Required for production and recommended for all environments.
EXPO_PUBLIC_BACKEND_URL=https://api.your-domain.com

# Public legal documents used by Login/Profile links.
EXPO_PUBLIC_PRIVACY_POLICY_URL=https://your-domain.com/privacy-policy
EXPO_PUBLIC_TERMS_URL=https://your-domain.com/terms-of-service

# AdMob config for Android release.
EXPO_PUBLIC_ADMOB_ANDROID_APP_ID=ca-app-pub-1111111111111111~2222222222
EXPO_PUBLIC_ADMOB_ANDROID_BANNER_ID=ca-app-pub-1111111111111111/3333333333
EXPO_PUBLIC_ADMOB_ANDROID_INTERSTITIAL_ID=ca-app-pub-1111111111111111/4444444444
EXPO_PUBLIC_ADMOB_ANDROID_REWARDED_ID=ca-app-pub-1111111111111111/5555555555

# Optional iOS IDs (if/when iOS is enabled).
EXPO_PUBLIC_ADMOB_IOS_APP_ID=ca-app-pub-1111111111111111~6666666666
EXPO_PUBLIC_ADMOB_IOS_BANNER_ID=ca-app-pub-1111111111111111/7777777777
EXPO_PUBLIC_ADMOB_IOS_INTERSTITIAL_ID=ca-app-pub-1111111111111111/8888888888
EXPO_PUBLIC_ADMOB_IOS_REWARDED_ID=ca-app-pub-1111111111111111/9999999999

# Development toggles.
# true: always use Google test ad units
# false: use production ad units from variables above
EXPO_PUBLIC_ADMOB_USE_TEST_IDS=true

# Optional comma-separated device IDs for explicit test devices.
EXPO_PUBLIC_ADMOB_TEST_DEVICE_IDS=

# Non-personalized ads request toggle.
EXPO_PUBLIC_ADMOB_NPA_ONLY=true
